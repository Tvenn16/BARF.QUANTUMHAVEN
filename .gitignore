local PageEvent=makePage("Event");local EventScroll,_=makeScroll(PageEvent)
makeSpacer(EventScroll,2)

-- ──────────────────────────────────────────────
-- PLANT RUSH  (v5.23 rewrite)
-- ──────────────────────────────────────────────
makeCollapsibleSection(EventScroll,"🌿","Plant Rush Event",function(body)

    -- Info label
    local prioLbl=Instance.new("TextLabel",body)
    prioLbl.Size=UDim2.new(1,0,0,36);prioLbl.BackgroundTransparency=1;prioLbl.LayoutOrder=1
    prioLbl.Text="Priority: 🌿 Small > Medium > Tough > 👾 Boss\n"
               .."Auto-equips TomatoShooter · forces 3rd-person · auto-aims camera"
    prioLbl.TextColor3=C.textDim;prioLbl.TextSize=FS.small;prioLbl.Font=Enum.Font.Code
    prioLbl.TextXAlignment=Enum.TextXAlignment.Left;prioLbl.TextWrapped=true;prioLbl.ZIndex=9

    -- Status labels
    local scanLblPR=Instance.new("TextLabel",body)
    scanLblPR.Size=UDim2.new(1,0,0,18);scanLblPR.BackgroundTransparency=1;scanLblPR.LayoutOrder=2
    scanLblPR.Text="Status: Idle — waiting for event"
    scanLblPR.TextColor3=C.textMid;scanLblPR.TextSize=FS.small;scanLblPR.Font=Enum.Font.Code
    scanLblPR.TextXAlignment=Enum.TextXAlignment.Left;scanLblPR.ZIndex=9
    Instance.new("UIPadding",scanLblPR).PaddingLeft=UDim.new(0,4)

    local targetLblPR=Instance.new("TextLabel",body)
    targetLblPR.Size=UDim2.new(1,0,0,18);targetLblPR.BackgroundTransparency=1;targetLblPR.LayoutOrder=3
    targetLblPR.Text=""
    targetLblPR.TextColor3=C.accent;targetLblPR.TextSize=FS.small;targetLblPR.Font=Enum.Font.Code
    targetLblPR.TextXAlignment=Enum.TextXAlignment.Left;targetLblPR.ZIndex=9
    Instance.new("UIPadding",targetLblPR).PaddingLeft=UDim.new(0,4)

    -- Toggle row
    local shootF=Instance.new("Frame",body)
    shootF.Size=UDim2.new(1,0,0,36);shootF.BackgroundTransparency=1;shootF.LayoutOrder=4

    makeToggleRow(shootF,"🎯","Auto Aim (PlantRush)",false,function(s)
        autoShootEnabled=s

        if not s then
            scanLblPR.Text="Status: Idle — waiting for event"
            targetLblPR.Text=""
            return
        end

        scanLblPR.Text="🔍 Starting scan loop…"

        task.spawn(function()
            -- Track whether we just equipped so we don't spam the equip call
            local lastEquipTime = 0

            while autoShootEnabled and active do

                -- ── 1. Find Runtime ──────────────────────────────────
                local ie      = workspace:FindFirstChild("InteractiveEvents")
                local pr      = ie and ie:FindFirstChild("PlantRush")
                local runtime = pr and pr:FindFirstChild("Runtime")

                if not runtime then
                    scanLblPR.Text  = "⏸ No PlantRush Runtime — waiting…"
                    targetLblPR.Text = ""
                    task.wait(0.2)
                    continue
                end

                -- ── 2. Collect enemies, stop at highest-priority tier ──
                local foundTier   = nil
                local foundTarget = nil

                for _, pname in ipairs(PLANT_RUSH_PRIORITY) do
                    for _, obj in ipairs(runtime:GetChildren()) do
                        if obj.Name == pname then
                            local hum = obj:FindFirstChildOfClass("Humanoid")
                            if hum and hum.Health > 0 then
                                -- Find best root part
                                local root = obj:FindFirstChild("HumanoidRootPart")
                                           or obj:FindFirstChild("Torso")
                                           or obj:FindFirstChild("UpperTorso")
                                if not root then
                                    for _, part in ipairs(obj:GetDescendants()) do
                                        if part:IsA("BasePart") then root=part;break end
                                    end
                                end
                                if root then
                                    foundTier   = pname
                                    foundTarget = {name=pname,root=root,hum=hum,
                                                   isBoss=(pname=="Boss Plant")}
                                    break
                                end
                            end
                        end
                    end
                    if foundTarget then break end
                end

                -- ── 3. No enemies ────────────────────────────────────
                if not foundTarget then
                    scanLblPR.Text  = "🔍 Runtime found — no alive enemies yet…"
                    targetLblPR.Text = ""
                    task.wait(0.2)
                    continue
                end

                -- ── 4. Auto-equip TomatoShooter + zoom out ───────────
                if not isHoldingTomato() then
                    local now = tick()
                    if now - lastEquipTime > 2 then   -- don't spam equip
                        lastEquipTime = now
                        equipTomatoShooter()           -- equips + zooms out
                        task.wait(0.15)
                    end
                else
                    -- Already equipped but might still be in first-person
                    -- (can happen after first equip); nudge every ~1 s
                    forceCameraZoomOut()
                end

                -- ── 5. Aim camera at target ───────────────────────────
                local cam = workspace.CurrentCamera
                if cam and foundTarget.root then
                    local targetPos = foundTarget.root.Position

                    -- Velocity lead for moving targets
                    local vel = Vector3.zero
                    if foundTarget.root:IsA("BasePart") then
                        pcall(function() vel = foundTarget.root.AssemblyLinearVelocity end)
                    end
                    local predicted = targetPos + vel * 0.10

                    local eyePos  = cam.CFrame.Position
                    local lookDir = predicted - eyePos
                    if lookDir.Magnitude > 0.01 then
                        cam.CFrame = CFrame.new(eyePos, eyePos + lookDir.Unit)
                    end

                    -- Move mouse cursor to the projected screen position
                    local screenPos, onScreen = cam:WorldToViewportPoint(predicted)
                    if onScreen then
                        local VIM = game:GetService("VirtualInputManager")
                        pcall(function()
                            VIM:SendMouseMoveEvent(
                                math.floor(screenPos.X),
                                math.floor(screenPos.Y),
                                game
                            )
                        end)
                    end
                end

                -- ── 6. Update HUD labels ──────────────────────────────
                local myRoot = player.Character
                    and player.Character:FindFirstChild("HumanoidRootPart")
                local dist = myRoot
                    and math.floor((foundTarget.root.Position - myRoot.Position).Magnitude)
                    or 0

                -- Count all enemies in runtime for the status bar
                local counts = {}
                for _, obj in ipairs(runtime:GetChildren()) do
                    counts[obj.Name] = (counts[obj.Name] or 0) + 1
                end
                scanLblPR.Text = string.format(
                    "👾 S:%d M:%d T:%d B:%d  |  Aiming → %s",
                    counts["Small Plant"]  or 0,
                    counts["Medium Plant"] or 0,
                    counts["Tough Plant"]  or 0,
                    counts["Boss Plant"]   or 0,
                    foundTarget.name
                )
                targetLblPR.Text = string.format(
                    "🎯 [%s]  HP:%.0f  Dist:%d",
                    foundTarget.isBoss and "👾 BOSS" or "🌿 "..foundTarget.name,
                    foundTarget.hum.Health,
                    dist
                )
                targetLblPR.TextColor3 = foundTarget.isBoss
                    and Color3.fromRGB(220,80,80)
                    or  Color3.fromRGB(80,220,130)

                task.wait(0.2)   -- 0.2 s scan + aim interval
            end

            scanLblPR.Text  = "Status: Idle — waiting for event"
            targetLblPR.Text = ""
        end)
    end,"autoShoot")
end)

makeSpacer(EventScroll,6)

makeCollapsibleSection(EventScroll,"🍯","Queen Bee Event",function(body)
    local hcStatusLbl=Instance.new("TextLabel",body);hcStatusLbl.Size=UDim2.new(1,0,0,18);hcStatusLbl.BackgroundTransparency=1;hcStatusLbl.Text="Status: Idle";hcStatusLbl.TextColor3=C.textMid;hcStatusLbl.TextSize=FS.small;hcStatusLbl.Font=Enum.Font.Code;hcStatusLbl.TextXAlignment=Enum.TextXAlignment.Left;hcStatusLbl.ZIndex=9;hcStatusLbl.LayoutOrder=1;Instance.new("UIPadding",hcStatusLbl).PaddingLeft=UDim.new(0,4)
    local hcF=Instance.new("Frame",body);hcF.Size=UDim2.new(1,0,0,36);hcF.BackgroundTransparency=1;hcF.LayoutOrder=2
    makeToggleRow(hcF,"🍯","Auto Honeycomb",false,function(state)
        honeycombEnabled=state
        if state then
            task.spawn(function()
                while honeycombEnabled and active do
                    if not honeycombEnabled then break end
                    if hasHoneyTokenInBackpack() then
                        hcStatusLbl.Text="🍯 Honey Token — using…"
                        while hasHoneyTokenInBackpack() and honeycombEnabled and active do useHoneyTokenIfPresent();task.wait(0.8) end
                        hcStatusLbl.Text="✅ Token(s) used — claiming honeycombs…";task.wait(0.5)
                    else hcStatusLbl.Text="🔍 Scanning for honeycombs…" end
                    if honeycombEnabled then claimAllHoneycombs() end
                    if honeycombEnabled then hcStatusLbl.Text="✔ Cycle done — waiting…";task.wait(2) end
                end
                hcStatusLbl.Text="Status: Idle"
            end)
        else hcStatusLbl.Text="Status: Idle" end
    end,"autoHoneycomb")
    local d1=Instance.new("Frame",body);d1.Size=UDim2.new(1,0,0,1);d1.BackgroundColor3=C.lineDivider;d1.BorderSizePixel=0;d1.LayoutOrder=3
    local honeyPotEnabled=false
    local hpStatusLbl=Instance.new("TextLabel",body);hpStatusLbl.Size=UDim2.new(1,0,0,18);hpStatusLbl.BackgroundTransparency=1;hpStatusLbl.Text="Status: Idle — no Honey Token found";hpStatusLbl.TextColor3=C.textMid;hpStatusLbl.TextSize=FS.small;hpStatusLbl.Font=Enum.Font.Code;hpStatusLbl.TextXAlignment=Enum.TextXAlignment.Left;hpStatusLbl.ZIndex=9;hpStatusLbl.LayoutOrder=4;Instance.new("UIPadding",hpStatusLbl).PaddingLeft=UDim.new(0,4)
    local hpF=Instance.new("Frame",body);hpF.Size=UDim2.new(1,0,0,36);hpF.BackgroundTransparency=1;hpF.LayoutOrder=5
    makeToggleRow(hpF,"🍯","Auto Honey Pot",false,function(state)
        honeyPotEnabled=state
        if state then task.spawn(function()
            while honeyPotEnabled and active do
                local backpack=player:FindFirstChild("Backpack");local honeyToken=nil
                if backpack then for _,item in ipairs(backpack:GetChildren()) do if item.Name:lower():find("honey token",1,true) then honeyToken=item;break end end end
                if not honeyToken then local char=player.Character;if char then for _,item in ipairs(char:GetChildren()) do if item.Name:lower():find("honey token",1,true) then honeyToken=item;break end end end end
                if not honeyToken then hpStatusLbl.Text="⏸ No Honey Token — standing by…";task.wait(3);continue end
                local machineOk,machinePart=pcall(function() return workspace.InteractiveEvents.QueenBee.HoneyJarMachine["Honey Jar Machine"] end)
                if not machineOk or not machinePart then hpStatusLbl.Text="⚠ Scanning Honey Jar Machine";task.wait(3);continue end
                local machinePos=nil
                if machinePart:IsA("BasePart") then machinePos=machinePart.Position
                elseif machinePart:IsA("Model") then local bp=machinePart:FindFirstChildWhichIsA("BasePart");if bp then machinePos=bp.Position end;if not machinePos then local ok2,wp=pcall(function() return machinePart.WorldPivot.Position end);if ok2 then machinePos=wp end end end
                if not machinePos then hpStatusLbl.Text="⚠ Could not get machine position";task.wait(3);continue end
                hpStatusLbl.Text=string.format("🍯 Token: %s — teleporting…",honeyToken.Name)
                teleportTo(machinePos);task.wait(0.3);hpStatusLbl.Text="🍯 Pressing E…"
                local VIM=game:GetService("VirtualInputManager");VIM:SendKeyEvent(true,Enum.KeyCode.E,false,game);task.wait(0.3);VIM:SendKeyEvent(false,Enum.KeyCode.E,false,game);task.wait(0.5)
                hpStatusLbl.Text=hasHoneyTokenInBackpack() and "✅ Token used — checking for more…" or "⏸ No more Honey Tokens — standing by…"
                task.wait(2)
            end;hpStatusLbl.Text="Status: Idle — no Honey Token found"
        end) else hpStatusLbl.Text="Status: Idle — no Honey Token found" end
    end,"autoHoneyPot")
end)

