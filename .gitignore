TitleLbl.Font=Enum.Font.GothamBold;TitleLbl.TextXAlignment=Enum.TextXAlignment.Left;TitleLbl.ZIndex=11
local TLine=Instance.new("Frame",InnerClip);TLine.Size=UDim2.new(1,-16,0,1);TLine.Position=UDim2.new(0,8,0,36);TLine.BackgroundColor3=C.accentDim;TLine.BorderSizePixel=0;TLine.ZIndex=10
Instance.new("UIGradient",TLine).Color=ColorSequence.new({ColorSequenceKeypoint.new(0,C.accent),ColorSequenceKeypoint.new(0.5,C.accentDim),ColorSequenceKeypoint.new(1,C.bg)})
local MinBtn=Instance.new("TextButton",TitleBar);MinBtn.Size=UDim2.new(0,22,0,22);MinBtn.Position=UDim2.new(1,-52,0.5,-11);MinBtn.BackgroundColor3=C.toggleOff;MinBtn.Text="–";MinBtn.TextColor3=C.textMid;MinBtn.TextSize=14;MinBtn.Font=Enum.Font.GothamBold;MinBtn.AutoButtonColor=false;MinBtn.ZIndex=12;Instance.new("UICorner",MinBtn).CornerRadius=UDim.new(0,5)
local CloseBtn=Instance.new("TextButton",TitleBar);CloseBtn.Size=UDim2.new(0,22,0,22);CloseBtn.Position=UDim2.new(1,-26,0.5,-11);CloseBtn.BackgroundColor3=Color3.fromRGB(80,22,22);CloseBtn.Text="✕";CloseBtn.TextColor3=C.red;CloseBtn.TextSize=12;CloseBtn.Font=Enum.Font.GothamBold;CloseBtn.AutoButtonColor=false;CloseBtn.ZIndex=12;Instance.new("UICorner",CloseBtn).CornerRadius=UDim.new(0,5)
MinBtn.MouseEnter:Connect(function() TweenService:Create(MinBtn,TweenInfo.new(0.12),{BackgroundColor3=C.accentDim,TextColor3=C.textBright}):Play() end)
