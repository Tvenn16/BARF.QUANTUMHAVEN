    local ufoSLbl=Instance.new("TextLabel",body);ufoSLbl.Size=UDim2.new(1,0,0,18);ufoSLbl.BackgroundTransparency=1;ufoSLbl.Text="Status: Idle — waiting for event";ufoSLbl.TextColor3=C.textMid;ufoSLbl.TextSize=FS.small;ufoSLbl.Font=Enum.Font.Code;ufoSLbl.TextXAlignment=Enum.TextXAlignment.Left;ufoSLbl.ZIndex=9;ufoSLbl.LayoutOrder=1;Instance.new("UIPadding",ufoSLbl).PaddingLeft=UDim.new(0,4)
