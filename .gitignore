local function buildSmartComposterInner(inner, floorNum, cap, capLabel, saveKey, plantNameRef, setPlantRef)
    local IF=Instance.new("Frame",inner);IF.Size=UDim2.new(1,0,0,50);IF.BackgroundColor3=C.panel;IF.BorderSizePixel=0;IF.LayoutOrder=1;Instance.new("UICorner",IF).CornerRadius=UDim.new(0,7);Instance.new("UIStroke",IF).Color=C.border
    local LBL=Instance.new("TextLabel",IF);LBL.Size=UDim2.new(1,-10,0,18);LBL.Position=UDim2.new(0,10,0,3);LBL.BackgroundTransparency=1;LBL.Text="🌱  Plant Name  —  Cap: "..capLabel;LBL.TextColor3=C.textDim;LBL.TextSize=FS.small;LBL.Font=Enum.Font.Code;LBL.TextXAlignment=Enum.TextXAlignment.Left;LBL.ZIndex=9
    local BOX=Instance.new("TextBox",IF);BOX.Size=UDim2.new(1,-16,0,22);BOX.Position=UDim2.new(0,8,0,24);BOX.BackgroundColor3=C.inputBg;BOX.BorderSizePixel=0;BOX.Text=plantNameRef();BOX.PlaceholderText="e.g. Durian";BOX.PlaceholderColor3=C.textDim;BOX.TextColor3=C.accent;BOX.TextSize=FS.normal;BOX.Font=Enum.Font.Code;BOX.ClearTextOnFocus=false;BOX.ZIndex=10;Instance.new("UICorner",BOX).CornerRadius=UDim.new(0,5);Instance.new("UIStroke",BOX).Color=C.accentDim
    BOX:GetPropertyChangedSignal("Text"):Connect(function() setPlantRef(BOX.Text) end)
    setPlantRef=function(val) setPlantRef(val);BOX.Text=val end
    local priceLbl=Instance.new("TextLabel",inner);priceLbl.Size=UDim2.new(1,0,0,16);priceLbl.BackgroundTransparency=1;priceLbl.LayoutOrder=2;priceLbl.TextColor3=C.textDim;priceLbl.TextSize=FS.small;priceLbl.Font=Enum.Font.Code;priceLbl.TextXAlignment=Enum.TextXAlignment.Left;priceLbl.ZIndex=9;Instance.new("UIPadding",priceLbl).PaddingLeft=UDim.new(0,2)
    local function updatePreview()
        local name=plantNameRef();local price=SEED_PRICES[name] or 0
        if price<=0 then priceLbl.Text=string.format("💡 %s: price unknown — will insert 1 seed",name)
        elseif price>=cap then priceLbl.Text=string.format("💡 %s = %s ≥ cap %s → 1 seed",name,formatValue(price),formatValue(cap))
        else local cnt=math.floor(cap/price);priceLbl.Text=string.format("💡 %s = %s → %d seeds (cap %s)",name,formatValue(price),cnt,formatValue(cap)) end
    end
    updatePreview()
    BOX:GetPropertyChangedSignal("Text"):Connect(updatePreview)
    local statusLbl=Instance.new("TextLabel",inner);statusLbl.Size=UDim2.new(1,0,0,18);statusLbl.BackgroundTransparency=1;statusLbl.LayoutOrder=3;statusLbl.Text="Status: Idle";statusLbl.TextColor3=C.textMid;statusLbl.TextSize=FS.small;statusLbl.Font=Enum.Font.Code;statusLbl.TextXAlignment=Enum.TextXAlignment.Left;statusLbl.ZIndex=9;Instance.new("UIPadding",statusLbl).PaddingLeft=UDim.new(0,2)
    local thwrap=Instance.new("Frame",inner);thwrap.Size=UDim2.new(1,0,0,36);thwrap.BackgroundTransparency=1;thwrap.BorderSizePixel=0;thwrap.LayoutOrder=4
    local th=Instance.new("Frame",thwrap);th.Size=UDim2.new(1,-80,1,0);th.BackgroundTransparency=1;th.BorderSizePixel=0
    local timerLbl=Instance.new("TextLabel",thwrap);timerLbl.Size=UDim2.new(0,78,1,0);timerLbl.Position=UDim2.new(1,-78,0,0);timerLbl.BackgroundTransparency=1;timerLbl.Text="";timerLbl.TextColor3=C.accent;timerLbl.TextSize=FS.small;timerLbl.Font=Enum.Font.Code;timerLbl.TextXAlignment=Enum.TextXAlignment.Right;timerLbl.ZIndex=9
    local smartEnabled=false
    makeToggleRow(th,"🧠","Smart Composter (cap "..capLabel..")",false,function(s)
        smartEnabled=s
        if s then runSmartComposter(floorNum,plantNameRef(),cap,statusLbl,function() return smartEnabled and active end,timerLbl)
        else statusLbl.Text="Status: Idle";timerLbl.Text="" end
    end,saveKey)
    return BOX,statusLbl
end

