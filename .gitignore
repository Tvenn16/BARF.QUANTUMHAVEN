local Body=Instance.new("Frame",InnerClip)
Body.Size=UDim2.new(1,0,1,-38);Body.Position=UDim2.new(0,0,0,38)
Body.BackgroundTransparency=1;Body.BorderSizePixel=0;Body.ZIndex=6

local Sidebar=Instance.new("Frame",Body)
Sidebar.Size=UDim2.new(0,SIDEBAR_W,1,0);Sidebar.BackgroundColor3=C.sidebar;Sidebar.BorderSizePixel=0;Sidebar.ZIndex=7
local SideDiv=Instance.new("Frame",Body)
SideDiv.Size=UDim2.new(0,1,1,0);SideDiv.Position=UDim2.new(0,SIDEBAR_W,0,0);SideDiv.BackgroundColor3=C.border;SideDiv.BorderSizePixel=0;SideDiv.ZIndex=7

local navPages={"Home","Farm","Auto","Event","Misc","Settings"}
local activeNav="Home";local navBtns={}
local icons={Home="🏠",Farm="🌾",Auto="⚡",Event="🎪",Misc="🔧",Settings="⚙"}
local NavLayout=Instance.new("UIListLayout",Sidebar);NavLayout.SortOrder=Enum.SortOrder.LayoutOrder;NavLayout.Padding=UDim.new(0,0)
local _navPad=Instance.new("Frame",Sidebar);_navPad.Size=UDim2.new(1,0,0,8);_navPad.BackgroundTransparency=1;_navPad.LayoutOrder=0

local function setNavActive(name)
    activeNav=name
    for n,btn in pairs(navBtns) do
        local isA=(n==name)
        for _,ch in ipairs(btn:GetChildren()) do if ch:IsA("Frame") then ch.Visible=isA end;if ch:IsA("TextLabel") then ch.TextColor3=isA and C.accent or C.textDim end end
        if isA then btn.BackgroundTransparency=0;btn.BackgroundColor3=C.navSel else btn.BackgroundTransparency=1 end
    end
    for _,child in ipairs(Body:GetChildren()) do if child.Name:sub(1,5)=="Page_" then child.Visible=(child.Name=="Page_"..name) end end
end

for i,pageName in ipairs(navPages) do
    local btn=Instance.new("TextButton",Sidebar);btn.Name="Nav_"..pageName;btn.Size=UDim2.new(1,0,0,52);btn.BackgroundColor3=Color3.fromRGB(0,0,0);btn.BackgroundTransparency=1;btn.Text="";btn.BorderSizePixel=0;btn.AutoButtonColor=false;btn.LayoutOrder=i
    local ico=Instance.new("TextLabel",btn);ico.Size=UDim2.new(1,0,0,24);ico.Position=UDim2.new(0,0,0,6);ico.BackgroundTransparency=1;ico.Text=icons[pageName] or "•";ico.TextSize=16;ico.Font=Enum.Font.GothamBold;ico.TextColor3=C.textDim;ico.TextXAlignment=Enum.TextXAlignment.Center;ico.ZIndex=8
    local lbl=Instance.new("TextLabel",btn);lbl.Size=UDim2.new(1,-4,0,16);lbl.Position=UDim2.new(0,2,0,28);lbl.BackgroundTransparency=1;lbl.Text=pageName;lbl.TextSize=FS.small;lbl.Font=Enum.Font.GothamBold;lbl.TextColor3=C.textDim;lbl.TextXAlignment=Enum.TextXAlignment.Center;lbl.TextWrapped=true;lbl.ZIndex=8
    local bar=Instance.new("Frame",btn);bar.Size=UDim2.new(0,3,0.6,0);bar.Position=UDim2.new(0,0,0.2,0);bar.BackgroundColor3=C.accent;bar.BorderSizePixel=0;bar.Visible=false;bar.ZIndex=9;Instance.new("UICorner",bar).CornerRadius=UDim.new(1,0)
    navBtns[pageName]=btn
    btn.MouseButton1Click:Connect(function() setNavActive(pageName) end)
    btn.MouseEnter:Connect(function() if activeNav~=pageName then TweenService:Create(btn,TweenInfo.new(0.1),{BackgroundTransparency=0,BackgroundColor3=C.navHov}):Play() end end)
    btn.MouseLeave:Connect(function() if activeNav~=pageName then TweenService:Create(btn,TweenInfo.new(0.1),{BackgroundTransparency=1}):Play() end end)
end

-- ══════════════════════════════════════════════
-- UI BUILDER HELPERS
-- ══════════════════════════════════════════════
local CONTENT_X=SIDEBAR_W+1
local function makePage(name)
    local page=Instance.new("Frame",Body)
    page.Name="Page_"..name;page.Size=UDim2.new(1,-CONTENT_X,1,0);page.Position=UDim2.new(0,CONTENT_X,0,0)
    page.BackgroundTransparency=1;page.BorderSizePixel=0;page.Visible=false;page.ZIndex=7;return page
end
local function makeScroll(parent)
    local scroll=Instance.new("ScrollingFrame",parent);scroll.Size=UDim2.new(1,0,1,0);scroll.BackgroundTransparency=1;scroll.BorderSizePixel=0;scroll.ScrollBarThickness=3;scroll.ScrollBarImageColor3=C.accentDim;scroll.CanvasSize=UDim2.new(0,0,0,0);scroll.ZIndex=8
    local layout=Instance.new("UIListLayout",scroll);layout.SortOrder=Enum.SortOrder.LayoutOrder;layout.Padding=UDim.new(0,0)
    local pad=Instance.new("UIPadding",scroll);pad.PaddingLeft=UDim.new(0,8);pad.PaddingRight=UDim.new(0,8);pad.PaddingTop=UDim.new(0,8);pad.PaddingBottom=UDim.new(0,8)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() scroll.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+16) end)
    return scroll,layout
end
local forceOffList={}
local function makeSpacer(parent,h) local s=Instance.new("Frame",parent);s.Size=UDim2.new(1,0,0,h);s.BackgroundTransparency=1;s.BorderSizePixel=0;return s end
local function makeSectionHeader(parent,icon,text)
    local row=Instance.new("Frame",parent);row.Size=UDim2.new(1,0,0,26);row.BackgroundColor3=Color3.fromRGB(14,24,14);row.BorderSizePixel=0;Instance.new("UICorner",row).CornerRadius=UDim.new(0,5)
    local lbl=Instance.new("TextLabel",row);lbl.Size=UDim2.new(1,-8,1,0);lbl.Position=UDim2.new(0,10,0,0);lbl.BackgroundTransparency=1;lbl.Text=icon.."  "..text;lbl.TextColor3=C.sectionHdr;lbl.TextSize=FS.small;lbl.Font=Enum.Font.GothamBold;lbl.TextXAlignment=Enum.TextXAlignment.Left;lbl.ZIndex=9
    local bar=Instance.new("Frame",row);bar.Size=UDim2.new(0,2,0.6,0);bar.Position=UDim2.new(0,0,0.2,0);bar.BackgroundColor3=C.accent;bar.BorderSizePixel=0;Instance.new("UICorner",bar).CornerRadius=UDim.new(1,0)
    return row
end
local function makeToggleRow(parent,icon,label,defaultOn,onToggle,saveKey)
    local row=Instance.new("TextButton",parent);row.Size=UDim2.new(1,0,0,36);row.BackgroundColor3=C.panel;row.BorderSizePixel=0;row.Text="";row.AutoButtonColor=false;Instance.new("UICorner",row).CornerRadius=UDim.new(0,7)
    local strip=Instance.new("Frame",row);strip.Size=UDim2.new(0,3,0.6,0);strip.Position=UDim2.new(0,0,0.2,0);strip.BackgroundColor3=defaultOn and C.accent or C.accentDim;strip.BorderSizePixel=0;Instance.new("UICorner",strip).CornerRadius=UDim.new(1,0)
    local lbl=Instance.new("TextLabel",row);lbl.Size=UDim2.new(1,-70,1,0);lbl.Position=UDim2.new(0,12,0,0);lbl.BackgroundTransparency=1;lbl.Text=icon.."  "..label;lbl.TextColor3=defaultOn and C.textBright or C.textMid;lbl.TextSize=FS.normal;lbl.Font=Enum.Font.Gotham;lbl.TextXAlignment=Enum.TextXAlignment.Left;lbl.ZIndex=9
    local badge=Instance.new("TextLabel",row);badge.Size=UDim2.new(0,36,0,18);badge.Position=UDim2.new(1,-44,0.5,-9);badge.BackgroundColor3=defaultOn and C.toggleOn or C.toggleOff;badge.Text=defaultOn and "ON" or "OFF";badge.TextColor3=defaultOn and Color3.fromRGB(0,0,0) or C.textDim;badge.TextSize=FS.small;badge.Font=Enum.Font.GothamBold;badge.BorderSizePixel=0;badge.ZIndex=9;Instance.new("UICorner",badge).CornerRadius=UDim.new(1,0)
    local state=defaultOn
    local function applyState(s)
        state=s;lbl.TextColor3=s and C.textBright or C.textMid;badge.Text=s and "ON" or "OFF"
        TweenService:Create(badge,TweenInfo.new(0.15),{BackgroundColor3=s and C.toggleOn or C.toggleOff,TextColor3=s and Color3.fromRGB(0,0,0) or C.textDim}):Play()
        TweenService:Create(strip,TweenInfo.new(0.15),{BackgroundColor3=s and C.accent or C.accentDim}):Play()
        if onToggle then onToggle(s) end
    end
    table.insert(forceOffList,function() if state then applyState(false) end end)
    row.MouseButton1Click:Connect(function() applyState(not state) end)
    row.MouseEnter:Connect(function() TweenService:Create(row,TweenInfo.new(0.1),{BackgroundColor3=C.rowHover}):Play() end)
    row.MouseLeave:Connect(function() TweenService:Create(row,TweenInfo.new(0.1),{BackgroundColor3=C.panel}):Play() end)
    if saveKey then saveRegistry.toggles[saveKey]={getState=function() return state end,setState=function(s) applyState(s) end} end
    return row,applyState
end

local function makeCollapsibleSection(parent,icon,label,buildContent)
    local isOpen=false
    local wrapper=Instance.new("Frame",parent);wrapper.Name="Section_"..label;wrapper.Size=UDim2.new(1,0,0,32);wrapper.BackgroundColor3=C.dropdownBg;wrapper.BorderSizePixel=0;wrapper.ClipsDescendants=true;Instance.new("UICorner",wrapper).CornerRadius=UDim.new(0,7);Instance.new("UIStroke",wrapper).Color=C.border
    local header=Instance.new("TextButton",wrapper);header.Size=UDim2.new(1,0,0,32);header.BackgroundColor3=C.dropdownHdr;header.BorderSizePixel=0;header.Text="";header.AutoButtonColor=false;header.ZIndex=10;Instance.new("UICorner",header).CornerRadius=UDim.new(0,6)
    local hBar=Instance.new("Frame",header);hBar.Size=UDim2.new(0,3,0.55,0);hBar.Position=UDim2.new(0,0,0.225,0);hBar.BackgroundColor3=C.accent;hBar.BorderSizePixel=0;Instance.new("UICorner",hBar).CornerRadius=UDim.new(1,0)
    local hIcon=Instance.new("TextLabel",header);hIcon.Size=UDim2.new(0,22,1,0);hIcon.Position=UDim2.new(0,10,0,0);hIcon.BackgroundTransparency=1;hIcon.Text=icon;hIcon.TextSize=14;hIcon.Font=Enum.Font.GothamBold;hIcon.TextColor3=C.accent;hIcon.TextXAlignment=Enum.TextXAlignment.Center;hIcon.ZIndex=11
    local hLabel=Instance.new("TextLabel",header);hLabel.Size=UDim2.new(1,-64,1,0);hLabel.Position=UDim2.new(0,34,0,0);hLabel.BackgroundTransparency=1;hLabel.Text=label;hLabel.TextColor3=C.textBright;hLabel.TextSize=FS.normal;hLabel.Font=Enum.Font.GothamBold;hLabel.TextXAlignment=Enum.TextXAlignment.Left;hLabel.ZIndex=11
    local chevron=Instance.new("TextLabel",header);chevron.Size=UDim2.new(0,20,1,0);chevron.Position=UDim2.new(1,-26,0,0);chevron.BackgroundTransparency=1;chevron.Text="▶";chevron.TextSize=10;chevron.Font=Enum.Font.GothamBold;chevron.TextColor3=C.accent;chevron.TextXAlignment=Enum.TextXAlignment.Center;chevron.ZIndex=11
    local inner=Instance.new("Frame",wrapper);inner.Name="Inner";inner.Size=UDim2.new(1,0,0,0);inner.Position=UDim2.new(0,0,0,32);inner.BackgroundTransparency=1;inner.BorderSizePixel=0;inner.ZIndex=10
    local iLayout=Instance.new("UIListLayout",inner);iLayout.SortOrder=Enum.SortOrder.LayoutOrder;iLayout.Padding=UDim.new(0,6)
    local iPad=Instance.new("UIPadding",inner);iPad.PaddingLeft=UDim.new(0,6);iPad.PaddingRight=UDim.new(0,6);iPad.PaddingTop=UDim.new(0,8);iPad.PaddingBottom=UDim.new(0,8)
    buildContent(inner)
    local function recalcH() return iLayout.AbsoluteContentSize.Y+16 end
    iLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h=recalcH();inner.Size=UDim2.new(1,0,0,h);if isOpen then wrapper.Size=UDim2.new(1,0,0,32+h) end
    end)
    local function setOpen(open)
        isOpen=open
        if open then chevron.Text="▼";local h=recalcH();inner.Size=UDim2.new(1,0,0,h);TweenService:Create(wrapper,TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,0,32+h)}):Play()
        else chevron.Text="▶";TweenService:Create(wrapper,TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Size=UDim2.new(1,0,0,32)}):Play() end
    end
    header.MouseButton1Click:Connect(function() setOpen(not isOpen) end)
    header.MouseEnter:Connect(function() TweenService:Create(header,TweenInfo.new(0.1),{BackgroundColor3=C.rowHover}):Play() end)
    header.MouseLeave:Connect(function() if not isOpen then TweenService:Create(header,TweenInfo.new(0.1),{BackgroundColor3=C.dropdownHdr}):Play() end end)
    return wrapper
end

local function makePlainDropdown(parent,prefix,icon,label,items,selectedTable)
    local isOpen=false
    local ITEM_H,HEADER_H,SEARCH_H,PAD=26,32,28,12
    local wrapper=Instance.new("Frame",parent);wrapper.Name="DD_"..label;wrapper.Size=UDim2.new(1,0,0,HEADER_H);wrapper.BackgroundColor3=C.dropdownBg;wrapper.BorderSizePixel=0;wrapper.ClipsDescendants=true;Instance.new("UICorner",wrapper).CornerRadius=UDim.new(0,7);Instance.new("UIStroke",wrapper).Color=C.border
    local header=Instance.new("TextButton",wrapper);header.Size=UDim2.new(1,0,0,HEADER_H);header.BackgroundColor3=C.dropdownHdr;header.BorderSizePixel=0;header.Text="";header.AutoButtonColor=false;header.ZIndex=10;Instance.new("UICorner",header).CornerRadius=UDim.new(0,6)
    local hBar=Instance.new("Frame",header);hBar.Size=UDim2.new(0,3,0.55,0);hBar.Position=UDim2.new(0,0,0.225,0);hBar.BackgroundColor3=C.accent;hBar.BorderSizePixel=0;Instance.new("UICorner",hBar).CornerRadius=UDim.new(1,0)
    Instance.new("TextLabel",header).Size=UDim2.new(0,22,1,0);local hIco=header:FindFirstChildOfClass("TextLabel");hIco.Position=UDim2.new(0,10,0,0);hIco.BackgroundTransparency=1;hIco.Text=icon;hIco.TextSize=14;hIco.Font=Enum.Font.GothamBold;hIco.TextColor3=C.accent;hIco.TextXAlignment=Enum.TextXAlignment.Center;hIco.ZIndex=11
    local hLbl=Instance.new("TextLabel",header);hLbl.Size=UDim2.new(1,-64,1,0);hLbl.Position=UDim2.new(0,34,0,0);hLbl.BackgroundTransparency=1;hLbl.Text=label;hLbl.TextColor3=C.textBright;hLbl.TextSize=FS.normal;hLbl.Font=Enum.Font.GothamBold;hLbl.TextXAlignment=Enum.TextXAlignment.Left;hLbl.ZIndex=11
    local chev=Instance.new("TextLabel",header);chev.Size=UDim2.new(0,20,1,0);chev.Position=UDim2.new(1,-26,0,0);chev.BackgroundTransparency=1;chev.Text="▶";chev.TextSize=10;chev.Font=Enum.Font.GothamBold;chev.TextColor3=C.accent;chev.TextXAlignment=Enum.TextXAlignment.Center;chev.ZIndex=11
    local inner=Instance.new("Frame",wrapper);inner.Name="Inner";inner.Position=UDim2.new(0,0,0,HEADER_H);inner.BackgroundTransparency=1;inner.BorderSizePixel=0;inner.ZIndex=10
    local iL=Instance.new("UIListLayout",inner);iL.SortOrder=Enum.SortOrder.LayoutOrder;iL.Padding=UDim.new(0,0)
    local iP=Instance.new("UIPadding",inner);iP.PaddingLeft=UDim.new(0,6);iP.PaddingRight=UDim.new(0,6);iP.PaddingTop=UDim.new(0,6);iP.PaddingBottom=UDim.new(0,6)
    local sW=Instance.new("Frame",inner);sW.Size=UDim2.new(1,0,0,SEARCH_H);sW.BackgroundColor3=C.searchBg;sW.BorderSizePixel=0;sW.LayoutOrder=0;Instance.new("UICorner",sW).CornerRadius=UDim.new(0,6);Instance.new("UIStroke",sW).Color=C.border
    local sIco=Instance.new("TextLabel",sW);sIco.Size=UDim2.new(0,20,1,0);sIco.Position=UDim2.new(0,4,0,0);sIco.BackgroundTransparency=1;sIco.Text="🔍";sIco.TextSize=11;sIco.Font=Enum.Font.GothamBold;sIco.ZIndex=12
    local sBox=Instance.new("TextBox",sW);sBox.Size=UDim2.new(1,-24,1,0);sBox.Position=UDim2.new(0,22,0,0);sBox.BackgroundTransparency=1;sBox.PlaceholderText="Search...";sBox.PlaceholderColor3=C.textDim;sBox.Text="";sBox.TextColor3=C.textBright;sBox.TextSize=FS.normal;sBox.Font=Enum.Font.Code;sBox.ClearTextOnFocus=false;sBox.BorderSizePixel=0;sBox.ZIndex=12
    if not saveRegistry.checkRows[prefix] then saveRegistry.checkRows[prefix]={} end
    local lo=1
    for _,itemName in ipairs(items) do
        local row=Instance.new("TextButton",inner);row.Size=UDim2.new(1,0,0,ITEM_H);row.BackgroundTransparency=1;row.BorderSizePixel=0;row.Text="";row.Name=prefix..itemName;row.AutoButtonColor=false;row.LayoutOrder=lo;lo=lo+1;row.ZIndex=11
        local checked=false
        local rowLbl=Instance.new("TextLabel",row);rowLbl.Size=UDim2.new(1,0,1,0);rowLbl.BackgroundTransparency=1;rowLbl.Text="  ▷ "..itemName;rowLbl.TextColor3=C.textDim;rowLbl.TextSize=FS.normal;rowLbl.Font=Enum.Font.Code;rowLbl.TextXAlignment=Enum.TextXAlignment.Left;rowLbl.ZIndex=12
        local function setChecked(val) checked=val;if checked then selectedTable[itemName]=true;rowLbl.Text="  ▶ "..itemName;rowLbl.TextColor3=C.accent else selectedTable[itemName]=nil;rowLbl.Text="  ▷ "..itemName;rowLbl.TextColor3=C.textDim end end
        row.MouseButton1Click:Connect(function() setChecked(not checked) end)
        row.MouseEnter:Connect(function() if not checked then rowLbl.TextColor3=C.textMid end end)
        row.MouseLeave:Connect(function() if not checked then rowLbl.TextColor3=C.textDim end end)
        saveRegistry.checkRows[prefix][itemName]={setChecked=setChecked}
    end
    sBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q=sBox.Text:lower()
        for _,ch in ipairs(inner:GetChildren()) do if ch:IsA("TextButton") and ch.Name:sub(1,#prefix)==prefix then ch.Visible=(q=="" or ch.Name:sub(#prefix+1):lower():find(q,1,true)~=nil) end end
    end)
    local function getH()
        local cnt=0;for _,ch in ipairs(inner:GetChildren()) do if (ch:IsA("Frame") or ch:IsA("TextButton")) and ch.Visible~=false then cnt=cnt+ch.AbsoluteSize.Y end end
        return HEADER_H+PAD+SEARCH_H+cnt+PAD
    end
    local function setOpen(open)
        isOpen=open
        if open then chev.Text="▼";local h=getH();inner.Size=UDim2.new(1,0,0,h-HEADER_H);TweenService:Create(wrapper,TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,0,h)}):Play()
        else chev.Text="▶";TweenService:Create(wrapper,TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Size=UDim2.new(1,0,0,HEADER_H)}):Play();sBox.Text="" end
    end
    header.MouseButton1Click:Connect(function() setOpen(not isOpen) end)
    header.MouseEnter:Connect(function() TweenService:Create(header,TweenInfo.new(0.1),{BackgroundColor3=C.rowHover}):Play() end)
    header.MouseLeave:Connect(function() TweenService:Create(header,TweenInfo.new(0.1),{BackgroundColor3=C.dropdownHdr}):Play() end)
    return wrapper
end

local function makeRarityDropdown(parent,prefix,icon,label,items,selectedTable)
    local isOpen=false
    local ITEM_H,HEADER_H,SEARCH_H,PAD=26,32,28,12
    local wrapper=Instance.new("Frame",parent);wrapper.Name="DD_"..label;wrapper.Size=UDim2.new(1,0,0,HEADER_H);wrapper.BackgroundColor3=C.dropdownBg;wrapper.BorderSizePixel=0;wrapper.ClipsDescendants=true;Instance.new("UICorner",wrapper).CornerRadius=UDim.new(0,7);Instance.new("UIStroke",wrapper).Color=C.border
    local header=Instance.new("TextButton",wrapper);header.Size=UDim2.new(1,0,0,HEADER_H);header.BackgroundColor3=C.dropdownHdr;header.BorderSizePixel=0;header.Text="";header.AutoButtonColor=false;header.ZIndex=10;Instance.new("UICorner",header).CornerRadius=UDim.new(0,6)
    local hBar=Instance.new("Frame",header);hBar.Size=UDim2.new(0,3,0.55,0);hBar.Position=UDim2.new(0,0,0.225,0);hBar.BackgroundColor3=C.accent;hBar.BorderSizePixel=0;Instance.new("UICorner",hBar).CornerRadius=UDim.new(1,0)
    local hIcoL=Instance.new("TextLabel",header);hIcoL.Size=UDim2.new(0,22,1,0);hIcoL.Position=UDim2.new(0,10,0,0);hIcoL.BackgroundTransparency=1;hIcoL.Text=icon;hIcoL.TextSize=14;hIcoL.Font=Enum.Font.GothamBold;hIcoL.TextColor3=C.accent;hIcoL.TextXAlignment=Enum.TextXAlignment.Center;hIcoL.ZIndex=11
    local hLbl=Instance.new("TextLabel",header);hLbl.Size=UDim2.new(1,-64,1,0);hLbl.Position=UDim2.new(0,34,0,0);hLbl.BackgroundTransparency=1;hLbl.Text=label;hLbl.TextColor3=C.textBright;hLbl.TextSize=FS.normal;hLbl.Font=Enum.Font.GothamBold;hLbl.TextXAlignment=Enum.TextXAlignment.Left;hLbl.ZIndex=11
    local chev=Instance.new("TextLabel",header);chev.Size=UDim2.new(0,20,1,0);chev.Position=UDim2.new(1,-26,0,0);chev.BackgroundTransparency=1;chev.Text="▶";chev.TextSize=10;chev.Font=Enum.Font.GothamBold;chev.TextColor3=C.accent;chev.TextXAlignment=Enum.TextXAlignment.Center;chev.ZIndex=11
    local inner=Instance.new("Frame",wrapper);inner.Name="Inner";inner.Position=UDim2.new(0,0,0,HEADER_H);inner.BackgroundTransparency=1;inner.BorderSizePixel=0;inner.ZIndex=10
    local iL=Instance.new("UIListLayout",inner);iL.SortOrder=Enum.SortOrder.LayoutOrder;iL.Padding=UDim.new(0,0)
    local iP=Instance.new("UIPadding",inner);iP.PaddingLeft=UDim.new(0,6);iP.PaddingRight=UDim.new(0,6);iP.PaddingTop=UDim.new(0,6);iP.PaddingBottom=UDim.new(0,6)
    local sW=Instance.new("Frame",inner);sW.Size=UDim2.new(1,0,0,SEARCH_H);sW.BackgroundColor3=C.searchBg;sW.BorderSizePixel=0;sW.LayoutOrder=0;Instance.new("UICorner",sW).CornerRadius=UDim.new(0,6);Instance.new("UIStroke",sW).Color=C.border
    local sIco=Instance.new("TextLabel",sW);sIco.Size=UDim2.new(0,20,1,0);sIco.Position=UDim2.new(0,4,0,0);sIco.BackgroundTransparency=1;sIco.Text="🔍";sIco.TextSize=11;sIco.Font=Enum.Font.GothamBold;sIco.ZIndex=12
    local sBox=Instance.new("TextBox",sW);sBox.Size=UDim2.new(1,-24,1,0);sBox.Position=UDim2.new(0,22,0,0);sBox.BackgroundTransparency=1;sBox.PlaceholderText="Search "..label:lower().."...";sBox.PlaceholderColor3=C.textDim;sBox.Text="";sBox.TextColor3=C.textBright;sBox.TextSize=FS.normal;sBox.Font=Enum.Font.Code;sBox.ClearTextOnFocus=false;sBox.BorderSizePixel=0;sBox.ZIndex=12
    if not saveRegistry.checkRows[prefix] then saveRegistry.checkRows[prefix]={} end
    local lo=1
    for _,rarity in ipairs(RARITY_ORDER) do
        local rc=RARITY_COLORS[rarity] or C.textMid
        local group=seedsByRarity[rarity];if not group then continue end
        local sepRow=Instance.new("Frame",inner);sepRow.Name="Sep_"..rarity;sepRow.Size=UDim2.new(1,0,0,20);sepRow.BackgroundColor3=Color3.fromRGB(14,22,14);sepRow.BorderSizePixel=0;sepRow.LayoutOrder=lo;lo=lo+1
        local sepLbl=Instance.new("TextLabel",sepRow);sepLbl.Size=UDim2.new(1,-8,1,0);sepLbl.Position=UDim2.new(0,8,0,0);sepLbl.BackgroundTransparency=1;sepLbl.Text="— "..rarity.." —";sepLbl.TextColor3=rc;sepLbl.TextSize=FS.small-1;sepLbl.Font=Enum.Font.GothamBold;sepLbl.TextXAlignment=Enum.TextXAlignment.Left;sepLbl.ZIndex=12
        for _,seed in ipairs(group) do
            local itemName=seed.name
            local inList=false;for _,item in ipairs(items) do if item==itemName then inList=true;break end end
            if not inList then continue end
            local row=Instance.new("TextButton",inner);row.Size=UDim2.new(1,0,0,ITEM_H);row.BackgroundTransparency=1;row.BorderSizePixel=0;row.Text="";row.Name=prefix..itemName;row.AutoButtonColor=false;row.LayoutOrder=lo;lo=lo+1;row.ZIndex=11
            local checked=false
            local rowLbl=Instance.new("TextLabel",row);rowLbl.Size=UDim2.new(1,0,1,0);rowLbl.BackgroundTransparency=1;rowLbl.Text="  ▷ "..itemName;rowLbl.TextColor3=C.textDim;rowLbl.TextSize=FS.normal;rowLbl.Font=Enum.Font.Code;rowLbl.TextXAlignment=Enum.TextXAlignment.Left;rowLbl.ZIndex=12
            local function setChecked(val) checked=val;if checked then selectedTable[itemName]=true;rowLbl.Text="  ▶ "..itemName;rowLbl.TextColor3=rc else selectedTable[itemName]=nil;rowLbl.Text="  ▷ "..itemName;rowLbl.TextColor3=C.textDim end end
            row.MouseButton1Click:Connect(function() setChecked(not checked) end)
            row.MouseEnter:Connect(function() if not checked then rowLbl.TextColor3=C.textMid end end)
            row.MouseLeave:Connect(function() if not checked then rowLbl.TextColor3=C.textDim end end)
            saveRegistry.checkRows[prefix][itemName]={setChecked=setChecked}
        end
    end
    sBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q=sBox.Text:lower()
        for _,ch in ipairs(inner:GetChildren()) do
            if ch.Name:sub(1,4)=="Sep_" then ch.Visible=(q=="")
            elseif ch.Name:sub(1,#prefix)==prefix then ch.Visible=(q=="" or ch.Name:sub(#prefix+1):lower():find(q,1,true)~=nil) end
        end
    end)
    local function getH()
        local cnt=0;for _,ch in ipairs(inner:GetChildren()) do if (ch:IsA("Frame") or ch:IsA("TextButton")) and ch.Visible~=false then cnt=cnt+ch.AbsoluteSize.Y end end
        return HEADER_H+PAD+SEARCH_H+cnt+PAD
    end
    local function setOpen(open)
        isOpen=open
        if open then chev.Text="▼";local h=getH();inner.Size=UDim2.new(1,0,0,h-HEADER_H);TweenService:Create(wrapper,TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,0,h)}):Play()
        else chev.Text="▶";TweenService:Create(wrapper,TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Size=UDim2.new(1,0,0,HEADER_H)}):Play();sBox.Text="" end
    end
    header.MouseButton1Click:Connect(function() setOpen(not isOpen) end)
    header.MouseEnter:Connect(function() TweenService:Create(header,TweenInfo.new(0.1),{BackgroundColor3=C.rowHover}):Play() end)
    header.MouseLeave:Connect(function() TweenService:Create(header,TweenInfo.new(0.1),{BackgroundColor3=C.dropdownHdr}):Play() end)
    return wrapper
end

-- ══════════════════════════════════════════════
-- MOVEMENT HELPERS
-- ══════════════════════════════════════════════
local function teleportTo(position) local char=player.Character;if char then local root=char:FindFirstChild("HumanoidRootPart");if root then root.CFrame=CFrame.new(position);task.wait(0.5) end end end
local function applySpeed(val) local char=player.Character;if char then local hum=char:FindFirstChildOfClass("Humanoid");if hum then hum.WalkSpeed=val end end end
task.spawn(function() while true do task.wait(0.1);if speedEnabled and active then applySpeed(speedValue) end end end)
local jumpConn=nil
local function setInfiniteJump(state)
    if jumpConn then jumpConn:Disconnect();jumpConn=nil end
    if state then jumpConn=UserInputService.JumpRequest:Connect(function() local char=player.Character;if char then local hum=char:FindFirstChildOfClass("Humanoid");if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end end end) end
end
local flyConn,bodyGyro,bodyVelocity=nil,nil,nil
local function setFly(state)
    local char=player.Character;if not char then return end
    local root=char:FindFirstChild("HumanoidRootPart");local hum=char:FindFirstChildOfClass("Humanoid");if not root or not hum then return end
    if state then
        hum.PlatformStand=true
        bodyGyro=Instance.new("BodyGyro",root);bodyGyro.MaxTorque=Vector3.new(1e9,1e9,1e9);bodyGyro.CFrame=root.CFrame;bodyGyro.P=1e6
        bodyVelocity=Instance.new("BodyVelocity",root);bodyVelocity.MaxForce=Vector3.new(1e9,1e9,1e9);bodyVelocity.Velocity=Vector3.zero
        flyConn=RunService.RenderStepped:Connect(function()
            if not flyEnabled or not active then return end
            local cam=workspace.CurrentCamera;if not cam then return end
            local md=Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then md=md+cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then md=md-cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then md=md-cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then md=md+cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then md=md+Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then md=md-Vector3.new(0,1,0) end
            bodyVelocity.Velocity=md*50;bodyGyro.CFrame=cam.CFrame
        end)
    else
        if flyConn then flyConn:Disconnect();flyConn=nil end
        if bodyGyro then bodyGyro:Destroy();bodyGyro=nil end
        if bodyVelocity then bodyVelocity:Destroy();bodyVelocity=nil end
        if hum then hum.PlatformStand=false end
    end
end
local noclipConn=nil
local function setNoclip(state)
    if noclipConn then noclipConn:Disconnect();noclipConn=nil end
    if state then
        noclipConn=RunService.Stepped:Connect(function()
            if not noclipEnabled or not active then return end
            local char=player.Character;if not char then return end
            for _,part in ipairs(char:GetDescendants()) do if part:IsA("BasePart") and part.CanCollide then part.CanCollide=false end end
        end)
    else local char=player.Character;if char then for _,part in ipairs(char:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide=true end end end end
end

-- ══════════════════════════════════════════════
-- TOMATO SHOOTER HELPERS  (v5.23)
-- ══════════════════════════════════════════════
-- isTomatoTool: returns true if the given Tool instance is a TomatoShooter
local function isTomatoTool(item)
    if not item:IsA("Tool") then return false end
    local n=item.Name:lower()
    return n:find("tomatoshooter",1,true)~=nil
        or n:find("tomato shooter",1,true)~=nil
        or n:find("tomato",1,true)~=nil
end

-- isHoldingTomato: returns true when char already has it equipped
local function isHoldingTomato()
    local char=player.Character;if not char then return false end
    for _,item in ipairs(char:GetChildren()) do
        if isTomatoTool(item) then return true end
    end
    return false
end

-- forceCameraZoomOut: pushes camera to third-person by temporarily bumping
-- CameraMinZoomDistance then immediately restoring it.
-- Uses the LocalPlayer's CameraMinZoomDistance character value if present,
-- otherwise manipulates the workspace Camera zoom.
local function forceCameraZoomOut(targetZoom)
    targetZoom = targetZoom or 12
    local cam = workspace.CurrentCamera
    if not cam then return end

    -- Method 1: bump min/max zoom via StarterPlayer properties (client-side writable)
    local sp = game:GetService("StarterPlayer")
    pcall(function()
        local prev = sp.CameraMaxZoomDistance
        local prevMin = sp.CameraMinZoomDistance
        sp.CameraMinZoomDistance = targetZoom
        sp.CameraMaxZoomDistance = math.max(targetZoom + 1, prev)
        task.wait(0.05)
        sp.CameraMinZoomDistance = prevMin
        sp.CameraMaxZoomDistance = prev
    end)

    -- Method 2: scroll-wheel simulation to force zoom out immediately
    -- Fires multiple scroll-out events so the engine moves the camera back
    local VIM = game:GetService("VirtualInputManager")
    task.spawn(function()
        for _=1, 10 do
            pcall(function()
                VIM:SendMouseWheelEvent(0, 0, false, game) -- false = scroll down = zoom out
            end)
            task.wait(0.02)
        end
    end)
end

-- equipTomatoShooter: finds the tool in backpack, equips it, then forces
-- the camera to zoom out so the game doesn't lock to first-person.
local function equipTomatoShooter()
    if isHoldingTomato() then
        -- Already equipped — just make sure we're not in first-person
        forceCameraZoomOut()
        return true
    end
    local char = player.Character
    local bp   = player:FindFirstChild("Backpack")
    if not char or not bp then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    for _, item in ipairs(bp:GetChildren()) do
        if isTomatoTool(item) then
            hum:EquipTool(item)
            -- Wait one frame for the equip to register, then zoom out
            task.wait(0.1)
            forceCameraZoomOut()
            task.wait(0.1)
            -- Second nudge in case the game re-asserts first-person on the
            -- next frame after tool activation
            forceCameraZoomOut()
            return true
        end
    end
    return false
end

-- ══════════════════════════════════════════════
-- FERTILIZER HELPERS
-- ══════════════════════════════════════════════
-- v5.22 FIX retained: Floor 1 has no FloorN subfolder
local function findDirtInFloorAnyPlot(floorNum, targetPlantName)
    local results={}
    local mapFolder=workspace:FindFirstChild("Map");if not mapFolder then return results end
    local plotsFolder=mapFolder:FindFirstChild("Plots");if not plotsFolder then return results end
    local lowerTarget=targetPlantName:lower()
    for _,plotFolder in ipairs(plotsFolder:GetChildren()) do
        local farmPlot
        if floorNum == 1 then
            farmPlot = plotFolder:FindFirstChild("FarmPlot")
        else
            local floorFolder = plotFolder:FindFirstChild("Floor"..floorNum)
            if floorFolder then
                farmPlot = floorFolder:FindFirstChild("FarmPlot")
            end
        end
        if not farmPlot then continue end
        for _,subPlot in ipairs(farmPlot:GetChildren()) do
            local dirtPart=subPlot:FindFirstChild("Dirt");if not dirtPart then continue end
            if targetPlantName=="" then
                table.insert(results,{dirt=dirtPart,plotName=plotFolder.Name,subName=subPlot.Name})
            else
                for _,child in ipairs(dirtPart:GetChildren()) do
                    if child.Name:lower():find(lowerTarget,1,true) then
                        table.insert(results,{dirt=dirtPart,plotName=plotFolder.Name,subName=subPlot.Name});break
                    end
                end
            end
        end
    end
    return results
end

local function scanFloor(floorNum, plantName)
    return findDirtInFloorAnyPlot(floorNum, plantName)
end

local function findFertilizerTool(toolSearchName)
    local backpack=player:FindFirstChild("Backpack");local char=player.Character;local lowerSearch=toolSearchName:lower()
    if backpack then for _,item in ipairs(backpack:GetChildren()) do if item.Name:lower():find(lowerSearch,1,true) then return item,"backpack" end end end
    if char then for _,item in ipairs(char:GetChildren()) do if item:IsA("Tool") and item.Name:lower():find(lowerSearch,1,true) then return item,"equipped" end end end
    return nil,nil
end
local function equipAndUseFertilizer(toolSearchName,dirtPart)
    local char=player.Character;if not char then return false end
    local hum=char:FindFirstChildOfClass("Humanoid");if not hum then return false end
    local tool,location=findFertilizerTool(toolSearchName);if not tool then return false end
    if location=="backpack" then hum:EquipTool(tool);task.wait(0.2) end
    if UseFertilizerEvent then pcall(function() UseFertilizerEvent:FireServer(dirtPart) end) end
    task.wait(0.4);return true
end

local FERT_TYPES={
    {key="normal",label="Normal Fertilizer",icon="🌿",toolName="Normal Fertilizer",cooldown=311,color=Color3.fromRGB(100,200,100)},
    {key="strong",label="Strong Fertilizer", icon="💪",toolName="Strong Fertilizer", cooldown=611,color=Color3.fromRGB(80,200,255)},
    {key="super", label="Super Fertilizer",  icon="⚡",toolName="Super Fertilizer",  cooldown=911,color=Color3.fromRGB(255,200,60)},
}

-- ══════════════════════════════════════════════
-- makeFertSection
-- ══════════════════════════════════════════════
local function makeFertSection(body, floorNum, saveKeySuffix)
    local fertEnabled=false
    local typeEnabled={normal=false,strong=false,super=false}
    local lo=0
    local function nextLO() lo=lo+1;return lo end
    local fertToggleApply=nil

    local scanLbl=Instance.new("TextLabel",body)
    scanLbl.Size=UDim2.new(1,0,0,16);scanLbl.BackgroundTransparency=1;scanLbl.LayoutOrder=nextLO()
    scanLbl.Text="Add plants per fertilizer type below, then Auto Fertilize turns on automatically"
    scanLbl.TextColor3=C.textMid;scanLbl.TextSize=FS.small-1
    scanLbl.Font=Enum.Font.Code;scanLbl.TextXAlignment=Enum.TextXAlignment.Left;scanLbl.ZIndex=9
    Instance.new("UIPadding",scanLbl).PaddingLeft=UDim.new(0,2)

    local th=Instance.new("Frame",body);th.Size=UDim2.new(1,0,0,36);th.BackgroundTransparency=1;th.BorderSizePixel=0;th.LayoutOrder=nextLO()

    local function hasAnyPlants()
        for _,tk in ipairs({"normal","strong","super"}) do
            for _ in pairs(fertPlants[floorNum][tk]) do return true end
        end
        return false
    end

    local function getEntriesForType(typeKey)
        local all={}
        for plantName in pairs(fertPlants[floorNum][typeKey]) do
            local entries=scanFloor(floorNum, plantName)
            for _,e in ipairs(entries) do e.plantName=plantName;table.insert(all,e) end
        end
        return all
    end

    local _,applyFertState=makeToggleRow(th,"🧪","Auto Fertilize",false,function(s)
        fertEnabled=s
        if s then
            task.spawn(function()
                while fertEnabled and active do
                    local anyEnabled=typeEnabled.normal or typeEnabled.strong or typeEnabled.super
                    if not anyEnabled then
                        scanLbl.Text="⚠ Enable at least one fertilizer type below";task.wait(2);continue
                    end
                    for _,fType in ipairs(FERT_TYPES) do
                        if not fertEnabled or not active then break end
                        if not typeEnabled[fType.key] then continue end
                        local entries=getEntriesForType(fType.key)
                        if #entries==0 then
                            scanLbl.Text=string.format("⚠ No plants set for %s",fType.label);task.wait(1);continue
                        end
                        if not findFertilizerTool(fType.toolName) then
                            scanLbl.Text=string.format("⚠ %s not in backpack — skipping",fType.label);task.wait(1);continue
                        end
                        local applied=0
                        for _,e in ipairs(entries) do
                            if not fertEnabled or not active then break end
                            scanLbl.Text=string.format("%s [%d/%d] → %s…",fType.icon,applied+1,#entries,e.plantName)
                            if equipAndUseFertilizer(fType.toolName,e.dirt) then applied=applied+1 end
                        end
                        scanLbl.Text=string.format("✅ %s → %d pot(s) — waiting %ds…",fType.label,applied,fType.cooldown)
                        for i=fType.cooldown,1,-1 do
                            if not fertEnabled or not active then break end
                            scanLbl.Text=string.format("⏳ [%s] %ds…",fType.label,i);task.wait(1)
                        end
                    end
                    if fertEnabled and active then scanLbl.Text="🔄 Cycle done — restarting…";task.wait(1) end
                end
                scanLbl.Text="Add plants per fertilizer type below"
            end)
        else
            scanLbl.Text="Paused"
        end
    end,"autoFertilize"..saveKeySuffix)
    fertToggleApply=applyFertState

    local div0=Instance.new("Frame",body);div0.Size=UDim2.new(1,0,0,1);div0.BackgroundColor3=C.lineDivider;div0.BorderSizePixel=0;div0.LayoutOrder=nextLO()

    for _,fType in ipairs(FERT_TYPES) do
        local tk=fType.key
        local typeTogF=Instance.new("Frame",body);typeTogF.Size=UDim2.new(1,0,0,36);typeTogF.BackgroundTransparency=1;typeTogF.LayoutOrder=nextLO()
        makeToggleRow(typeTogF,fType.icon,fType.label.."  ["..({[311]="5m 7s",[611]="10m 7s",[911]="15m 10s"})[fType.cooldown].."]",false,function(s)
            typeEnabled[tk]=s
            if s and hasAnyPlants() and fertToggleApply then
                fertToggleApply(true)
            end
        end,"autoFert"..fType.label:gsub(" ","")..saveKeySuffix)

        local addRowF=Instance.new("Frame",body)
        addRowF.Size=UDim2.new(1,0,0,28);addRowF.BackgroundColor3=C.panel
        addRowF.BorderSizePixel=0;addRowF.LayoutOrder=nextLO()
        Instance.new("UICorner",addRowF).CornerRadius=UDim.new(0,5)
        Instance.new("UIStroke",addRowF).Color=C.border
        local addBox=Instance.new("TextBox",addRowF)
        addBox.Size=UDim2.new(1,-56,1,0);addBox.Position=UDim2.new(0,6,0,0)
        addBox.BackgroundTransparency=1;addBox.Text=""
        addBox.PlaceholderText="Type Plant Name";addBox.PlaceholderColor3=C.textDim
        addBox.TextColor3=fType.color;addBox.TextSize=FS.small
        addBox.Font=Enum.Font.Code;addBox.ClearTextOnFocus=false;addBox.BorderSizePixel=0;addBox.ZIndex=9
        local addBtn=Instance.new("TextButton",addRowF)
        addBtn.Size=UDim2.new(0,48,1,-4);addBtn.Position=UDim2.new(1,-52,0,2)
        addBtn.BackgroundColor3=C.accentDim;addBtn.Text="Add"
        addBtn.TextColor3=C.textBright;addBtn.TextSize=FS.small
        addBtn.Font=Enum.Font.GothamBold;addBtn.BorderSizePixel=0;addBtn.AutoButtonColor=false;addBtn.ZIndex=10
        Instance.new("UICorner",addBtn).CornerRadius=UDim.new(0,4)

        local typeScanLbl=Instance.new("TextLabel",body)
        typeScanLbl.Size=UDim2.new(1,0,0,14);typeScanLbl.BackgroundTransparency=1;typeScanLbl.LayoutOrder=nextLO()
        typeScanLbl.Text="";typeScanLbl.TextColor3=fType.color;typeScanLbl.TextSize=FS.small-2
        typeScanLbl.Font=Enum.Font.Code;typeScanLbl.TextXAlignment=Enum.TextXAlignment.Left;typeScanLbl.ZIndex=9
        Instance.new("UIPadding",typeScanLbl).PaddingLeft=UDim.new(0,4)

        local listF=Instance.new("Frame",body)
        listF.Size=UDim2.new(1,0,0,0);listF.BackgroundTransparency=1
        listF.BorderSizePixel=0;listF.LayoutOrder=nextLO();listF.ClipsDescendants=false
        local lLayout=Instance.new("UIListLayout",listF)
        lLayout.SortOrder=Enum.SortOrder.LayoutOrder;lLayout.Padding=UDim.new(0,2)
        lLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            listF.Size=UDim2.new(1,0,0,lLayout.AbsoluteContentSize.Y)
        end)

        local capturedTk=tk
        local capturedType=fType

        local function refreshList()
            for _,ch in ipairs(listF:GetChildren()) do if not ch:IsA("UIListLayout") then ch:Destroy() end end
            local names={};for n in pairs(fertPlants[floorNum][capturedTk]) do table.insert(names,n) end;table.sort(names)
            for _,name in ipairs(names) do
                local row=Instance.new("Frame",listF);row.Size=UDim2.new(1,0,0,22);row.BackgroundColor3=C.panel;row.BorderSizePixel=0;Instance.new("UICorner",row).CornerRadius=UDim.new(0,4)
                local nLbl=Instance.new("TextLabel",row);nLbl.Size=UDim2.new(1,-28,1,0);nLbl.Position=UDim2.new(0,6,0,0);nLbl.BackgroundTransparency=1;nLbl.Text="🌱 "..name;nLbl.TextColor3=capturedType.color;nLbl.TextSize=FS.small;nLbl.Font=Enum.Font.Code;nLbl.TextXAlignment=Enum.TextXAlignment.Left;nLbl.ZIndex=9
                local dBtn=Instance.new("TextButton",row);dBtn.Size=UDim2.new(0,20,0,16);dBtn.Position=UDim2.new(1,-24,0.5,-8);dBtn.BackgroundColor3=Color3.fromRGB(60,20,20);dBtn.Text="✕";dBtn.TextColor3=C.red;dBtn.TextSize=FS.small;dBtn.Font=Enum.Font.GothamBold;dBtn.BorderSizePixel=0;dBtn.AutoButtonColor=false;dBtn.ZIndex=10;Instance.new("UICorner",dBtn).CornerRadius=UDim.new(0,3)
                local capN=name;dBtn.MouseButton1Click:Connect(function() fertPlants[floorNum][capturedTk][capN]=nil;refreshList() end)
            end
        end

        local function addPlant()
            local txt=addBox.Text:match("^%s*(.-)%s*$")
            if not txt or #txt==0 then return end
            fertPlants[floorNum][capturedTk][txt]=true
            addBox.Text=""
            refreshList()
            task.spawn(function()
                typeScanLbl.Text=string.format("🔍 Scanning Floor %d for '%s'…",floorNum,txt)
                local entries=scanFloor(floorNum,txt)
                if #entries==0 then
                    typeScanLbl.Text=string.format("⚠ '%s' not found in Floor %d",txt,floorNum)
                else
                    typeScanLbl.Text=string.format("✅ '%s' → %d pot(s) found",txt,#entries)
                end
            end)
            if typeEnabled[capturedTk] and fertToggleApply then
                fertToggleApply(true)
            end
        end
        addBtn.MouseButton1Click:Connect(addPlant)
        addBox.FocusLost:Connect(function(enter) if enter then addPlant() end end)
        addBtn.MouseEnter:Connect(function() TweenService:Create(addBtn,TweenInfo.new(0.1),{BackgroundColor3=C.accent}):Play() end)
        addBtn.MouseLeave:Connect(function() TweenService:Create(addBtn,TweenInfo.new(0.1),{BackgroundColor3=C.accentDim}):Play() end)

        if not fertRefreshCallbacks[floorNum] then fertRefreshCallbacks[floorNum]={} end
        fertRefreshCallbacks[floorNum][tk]=refreshList

        refreshList()

        local divLine=Instance.new("Frame",body);divLine.Size=UDim2.new(1,0,0,1);divLine.BackgroundColor3=C.lineDivider;divLine.BorderSizePixel=0;divLine.LayoutOrder=nextLO()
    end
end

-- ══════════════════════════════════════════════
-- VALUE FORMATTER
-- ══════════════════════════════════════════════
local function formatValue(v)
    if v>=1e15 then return string.format("%.2fQ",v/1e15)
    elseif v>=1e12 then return string.format("%.2fT",v/1e12)
    elseif v>=1e9  then return string.format("%.2fB",v/1e9)
    elseif v>=1e6  then return string.format("%.2fM",v/1e6)
    elseif v>=1e3  then return string.format("%.1fK",v/1e3)
    else return tostring(math.floor(v)) end
end

-- ══════════════════════════════════════════════
-- SMART COMPOSTER
-- ══════════════════════════════════════════════
local function runSmartComposter(floorNum,seedName,maxValue,statusLbl,enabledRef,timerLbl)
    task.spawn(function()
        local cycle=0
        while enabledRef() and active do
            cycle=cycle+1
            local seedId=seedName.."_1_Normal"
            local seedPrice=SEED_PRICES[seedName] or 0
            local count,priceNote
            if seedPrice<=0 then count=1;priceNote="unknown price"
            elseif seedPrice>=maxValue then count=1;priceNote=string.format("%s/seed ≥ cap %s → inserting 1",formatValue(seedPrice),formatValue(maxValue))
            else count=math.floor(maxValue/seedPrice);priceNote=string.format("%s/seed × %d = %s (cap %s)",formatValue(seedPrice),count,formatValue(count*seedPrice),formatValue(maxValue)) end
            statusLbl.Text=string.format("⏳ Cycle %d — Inserting %d×%s  [%s]…",cycle,count,seedName,priceNote)
            local inserted=0;local batchSize=10
            while inserted<count and enabledRef() and active do
                local toInsert=math.min(batchSize,count-inserted)
                local ok,err=pcall(function() InsertSeedEvent:InvokeServer(floorNum,seedId,toInsert) end)
                if ok then inserted=inserted+toInsert;statusLbl.Text=string.format("⏳ Cycle %d — Inserted %d / %d seeds…",cycle,inserted,count)
                else statusLbl.Text=string.format("⚠ Insert error: %s",tostring(err));task.wait(1);break end
                task.wait(0.3)
            end
            if not enabledRef() or not active then break end
            statusLbl.Text=string.format("⏳ Cycle %d — Pulling lever…",cycle)
            pcall(function() PullLeverEvent:InvokeServer(floorNum) end)
            statusLbl.Text=string.format("✔ Cycle %d done — cooldown 305s…",cycle)
            for i=305,1,-1 do
                if not enabledRef() or not active then break end
                statusLbl.Text=string.format("⏳ [Cycle %d] Cooldown: %ds…",cycle,i)
                if timerLbl then timerLbl.Text=string.format(" ⏱ %ds",i) end
                task.wait(1)
            end
            if timerLbl then timerLbl.Text="" end
            if enabledRef() and active then statusLbl.Text=string.format("✅ Starting cycle %d — seed: %s",cycle+1,seedName);task.wait(0.5) end
        end
        statusLbl.Text="Status: Idle"
        if timerLbl then timerLbl.Text="" end
    end)
end

-- ══════════════════════════════════════════════
-- HONEYCOMB / UFO HELPERS
-- ══════════════════════════════════════════════
local function getRuntimeHoneycombs()
    return workspace:FindFirstChild("InteractiveEvents") and workspace.InteractiveEvents:FindFirstChild("QueenBee") and workspace.InteractiveEvents.QueenBee:FindFirstChild("RuntimeHoneycombs")
end
local function getNilByDebugId(debugId) for _,obj in ipairs(getnilinstances()) do if obj:GetDebugId()==debugId then return obj end end end
local function hasHoneyTokenInBackpack()
    local backpack=player:FindFirstChild("Backpack");local char=player.Character
    if backpack then for _,item in ipairs(backpack:GetChildren()) do if item.Name:lower():find("honey token",1,true) then return true end end end
    if char then for _,item in ipairs(char:GetChildren()) do if item.Name:lower():find("honey token",1,true) then return true end end end
    return false
end
local function useHoneyTokenIfPresent()
    if not hasHoneyTokenInBackpack() then return false end
    local machineOk,machinePart=pcall(function() return workspace.InteractiveEvents.QueenBee.HoneyJarMachine["Honey Jar Machine"] end)
    if not machineOk or not machinePart then return false end
    local machinePos=nil
    if machinePart:IsA("BasePart") then machinePos=machinePart.Position
    elseif machinePart:IsA("Model") then
        local bp=machinePart:FindFirstChildWhichIsA("BasePart");if bp then machinePos=bp.Position end
        if not machinePos then local ok2,wp=pcall(function() return machinePart.WorldPivot.Position end);if ok2 then machinePos=wp end end
    end
    if not machinePos then return false end
    teleportTo(machinePos);task.wait(0.3)
    local VIM=game:GetService("VirtualInputManager");VIM:SendKeyEvent(true,Enum.KeyCode.E,false,game);task.wait(0.3);VIM:SendKeyEvent(false,Enum.KeyCode.E,false,game);task.wait(0.5)
    return true
end
local function claimAllHoneycombs()
    while hasHoneyTokenInBackpack() do useHoneyTokenIfPresent();task.wait(0.5) end
    local rf=getRuntimeHoneycombs();if not rf then return end
    local children=rf:GetChildren();if #children==0 then return end
    for _,honeycomb in ipairs(children) do
        if not honeycombEnabled or not active then break end
        local pos=nil
        if honeycomb:IsA("BasePart") then pos=honeycomb.Position else local bp=honeycomb:FindFirstChildWhichIsA("BasePart");if bp then pos=bp.Position end end
        if not pos then local ok2,wp=pcall(function() return honeycomb.WorldPivot.Position end);if ok2 then pos=wp end end
        if pos then teleportTo(pos) end
        local VIM2=game:GetService("VirtualInputManager");VIM2:SendKeyEvent(true,Enum.KeyCode.E,false,game);task.wait(0.5);VIM2:SendKeyEvent(false,Enum.KeyCode.E,false,game);task.wait(0.1)
        local nilObj=getNilByDebugId(honeycomb:GetDebugId());firesignal(HoneycombEvent.OnClientEvent,nilObj or honeycomb,player);task.wait(0.3)
    end
end
local function scanUfoDrops()
    local ie=workspace:FindFirstChild("InteractiveEvents");if not ie then return {} end
    local drops={};local ai=ie:FindFirstChild("AlienInvasion")
    if ai then for _,obj in ipairs(ai:GetChildren()) do if obj:IsA("BasePart") or obj:IsA("Model") then table.insert(drops,obj) end end end
    return drops
end
local function claimDropList(drops)
    local VIM=game:GetService("VirtualInputManager");local claimed=0
    for _,drop in ipairs(drops) do
        if not ufoEnabled or not active then break end
        local pos=nil
        if drop:IsA("BasePart") then pos=drop.Position elseif drop:IsA("Model") then local bp=drop:FindFirstChildWhichIsA("BasePart");if bp then pos=bp.Position end;if not pos then local ok,wp=pcall(function() return drop.WorldPivot.Position end);if ok then pos=wp end end end
        if pos then teleportTo(pos) end
        VIM:SendKeyEvent(true,Enum.KeyCode.E,false,game);task.wait(1);VIM:SendKeyEvent(false,Enum.KeyCode.E,false,game);task.wait(0.3)
        claimed=claimed+1
    end;return claimed
end

