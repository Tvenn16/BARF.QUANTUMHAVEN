discordBtn.MouseLeave:Connect(function() TweenService:Create(discordBtn,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(14,30,60)}):Play();TweenService:Create(dStr,TweenInfo.new(0.1),{Color=Color3.fromRGB(40,80,160)}):Play();discordBtn.Text="🔗  Copy Discord Link";discordBtn.TextColor3=Color3.fromRGB(88,170,255) end)
