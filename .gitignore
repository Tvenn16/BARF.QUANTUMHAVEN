-- ══════════════════════════════════════════════
-- SAVE / LOAD
-- ══════════════════════════════════════════════
local fertPlants={}
for fi=1,4 do
    fertPlants[fi]={}
    for _,tk in ipairs({"normal","strong","super"}) do
        fertPlants[fi][tk]={}
    end
end

local fertRefreshCallbacks={}

local function doSave()
    local sd={
        keybind=currentKeybind and currentKeybind.Name or "RightBracket",speedValue=speedValue,
        toggles={},seeds={},gear={},discard={},raritySelected={},
        farm2PlantName=FARM2_PLANT_NAME,farmPlantName=FARM_PLANT_NAME,farm4PlantName=FARM4_PLANT_NAME,
    }
    for fi=1,4 do
        for tidx,tk in ipairs({"normal","strong","super"}) do
            local key=string.format("fertCustom%dF%d",tidx,fi)
            sd[key]={}
            for n in pairs(fertPlants[fi][tk]) do table.insert(sd[key],n) end
        end
    end
    for key,ctrl in pairs(saveRegistry.toggles) do
        if key and ctrl and type(ctrl.getState)=="function" then local ok,val=pcall(ctrl.getState);if ok and val~=nil then sd.toggles[tostring(key)]=val end end
    end
    for n in pairs(selectedSeeds) do if n then table.insert(sd.seeds,tostring(n)) end end
    for n in pairs(selectedGear)  do if n then table.insert(sd.gear, tostring(n)) end end
    for n in pairs(selectedDiscard) do if n then table.insert(sd.discard,tostring(n)) end end
    for n in pairs(selectedRarities) do if n then table.insert(sd.raritySelected,tostring(n)) end end
    local eOk,enc=pcall(jsonEncode,sd);if not eOk then return end;pcall(writefile,SAVE_FILE,enc)
end

local function doLoad()
    local exists=false
    if type(isfile)=="function" then exists=isfile(SAVE_FILE) else local ok,c=pcall(readfile,SAVE_FILE);exists=ok and type(c)=="string" and #c>2 end
    if not exists then return end
    local ok,content=pcall(readfile,SAVE_FILE);if not ok or type(content)~="string" or #content<2 then return end
    local dOk,data=pcall(jsonDecode,content);if not dOk or type(data)~="table" then return end
    if data.keybind and data.keybind~="" then local e=Enum.KeyCode[data.keybind];if e then currentKeybind=e;if saveRegistry.setKeybind then pcall(saveRegistry.setKeybind,e) end end end
    if data.speedValue then speedValue=data.speedValue;if saveRegistry.setSpeedValue then pcall(saveRegistry.setSpeedValue,speedValue) end end
    if data.farm2PlantName and data.farm2PlantName~="" then FARM2_PLANT_NAME=data.farm2PlantName;if saveRegistry.setFarm2PlantName then pcall(saveRegistry.setFarm2PlantName,data.farm2PlantName) end end
    if data.farmPlantName  and data.farmPlantName~=""  then FARM_PLANT_NAME=data.farmPlantName;if saveRegistry.setFarmPlantName then pcall(saveRegistry.setFarmPlantName,data.farmPlantName) end end
    if data.farm4PlantName and data.farm4PlantName~="" then FARM4_PLANT_NAME=data.farm4PlantName;if saveRegistry.setFarm4PlantName then pcall(saveRegistry.setFarm4PlantName,data.farm4PlantName) end end
    for fi=1,4 do
        for tidx,tk in ipairs({"normal","strong","super"}) do
            local key=string.format("fertCustom%dF%d",tidx,fi)
            if data[key] then
                for _,n in ipairs(data[key]) do fertPlants[fi][tk][n]=true end
            end
        end
    end
    task.delay(0,function()
        for key,state in pairs(data.toggles) do local ctrl=saveRegistry.toggles[key];if ctrl and type(ctrl.setState)=="function" then pcall(ctrl.setState,state) end end
        local sg=saveRegistry.checkRows["SeedRow_"];if sg then for _,n in ipairs(data.seeds or {}) do local e=sg[n];if e then pcall(e.setChecked,true) end end end
        local gg=saveRegistry.checkRows["GearRow_"];if gg then for _,n in ipairs(data.gear or {}) do local e=gg[n];if e then pcall(e.setChecked,true) end end end
        local dg=saveRegistry.checkRows["DiscardRow_"];if dg then for _,n in ipairs(data.discard or {}) do local e=dg[n];if e then pcall(e.setChecked,true) end end end
        for fi=1,4 do
            if fertRefreshCallbacks[fi] then
                for _,tk in ipairs({"normal","strong","super"}) do
                    if fertRefreshCallbacks[fi][tk] then pcall(fertRefreshCallbacks[fi][tk]) end
                end
            end
        end
    end)
end

