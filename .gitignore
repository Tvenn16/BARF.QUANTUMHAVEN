-- ══════════════════════════════════════════════
-- JSON HELPERS
-- ══════════════════════════════════════════════
local function jsonStr(s) return tostring(s):gsub('\\','\\\\'):gsub('"','\\"'):gsub('\n','\\n'):gsub('\r','\\r'):gsub('\t','\\t') end
local function jsonEncode(t)
    local lines={'{'};table.insert(lines,string.format('  "keybind": "%s",',jsonStr(t.keybind or "RightBracket")))
    table.insert(lines,string.format('  "speedValue": %d,',t.speedValue or 16))
    table.insert(lines,string.format('  "farm2PlantName": "%s",',jsonStr(t.farm2PlantName or "Durian")))
    table.insert(lines,string.format('  "farmPlantName": "%s",',jsonStr(t.farmPlantName or "Durian")))
    table.insert(lines,string.format('  "farm4PlantName": "%s",',jsonStr(t.farm4PlantName or "Durian")))
    table.insert(lines,'  "toggles": {')
    local tkeys={};for k in pairs(t.toggles or {}) do table.insert(tkeys,k) end;table.sort(tkeys)
    for i,k in ipairs(tkeys) do table.insert(lines,string.format('    "%s": %s%s',jsonStr(k),t.toggles[k] and "true" or "false",i<#tkeys and "," or "")) end
    table.insert(lines,'  },')
    local function writeArr(key,arr,last)
        table.insert(lines,string.format('  "%s": [',key))
        for i,s in ipairs(arr) do table.insert(lines,string.format('    "%s"%s',jsonStr(s),i<#arr and "," or "")) end
        table.insert(lines,last and '  ]' or '  ],')
    end
    writeArr("seeds",t.seeds or {});writeArr("gear",t.gear or {});writeArr("discard",t.discard or {})
    writeArr("fertCustom1F1",t.fertCustom1F1 or {});writeArr("fertCustom1F2",t.fertCustom1F2 or {});writeArr("fertCustom1F3",t.fertCustom1F3 or {});writeArr("fertCustom1F4",t.fertCustom1F4 or {})
    writeArr("fertCustom2F1",t.fertCustom2F1 or {});writeArr("fertCustom2F2",t.fertCustom2F2 or {});writeArr("fertCustom2F3",t.fertCustom2F3 or {});writeArr("fertCustom2F4",t.fertCustom2F4 or {})
    writeArr("fertCustom3F1",t.fertCustom3F1 or {});writeArr("fertCustom3F2",t.fertCustom3F2 or {});writeArr("fertCustom3F3",t.fertCustom3F3 or {});writeArr("fertCustom3F4",t.fertCustom3F4 or {})
    writeArr("raritySelected",t.raritySelected or {},true)
    table.insert(lines,'}');return table.concat(lines,'\n')
end
local function parseJsonString(str,pos)
    pos=pos+1;local chars,len={},#str
    while pos<=len do
        local c=str:sub(pos,pos)
        if c=='"' then return table.concat(chars),pos+1
        elseif c=='\\' then pos=pos+1;local e=str:sub(pos,pos);table.insert(chars,({['"']='"',['\\']='\\',n='\n',r='\r',t='\t'})[e] or e)
        else table.insert(chars,c) end;pos=pos+1
    end;return nil,pos
end
local function jsonDecode(str)
    local result={toggles={},seeds={},gear={},discard={},raritySelected={},farm2PlantName="Durian",farmPlantName="Durian",farm4PlantName="Durian",speedValue=16}
    for _,fk in ipairs({"fertCustom1","fertCustom2","fertCustom3"}) do
        for _,fl in ipairs({"F1","F2","F3","F4"}) do result[fk..fl]={} end
    end
    local len,pos=#str,1
    local function skipWS() while pos<=len and str:sub(pos,pos):match('%s') do pos=pos+1 end end
    local function readString() skipWS();if str:sub(pos,pos)~='"' then return nil end;local v,np=parseJsonString(str,pos);pos=np;return v end
    local function readBool() skipWS();if str:sub(pos,pos+3)=="true" then pos=pos+4;return true end;if str:sub(pos,pos+4)=="false" then pos=pos+5;return false end end
    local function readNumber() skipWS();local n="";while pos<=len and str:sub(pos,pos):match('[%d%.%-]') do n=n..str:sub(pos,pos);pos=pos+1 end;return tonumber(n) end
    local function readArray()
        local arr={};if str:sub(pos,pos)=='[' then pos=pos+1 end
        while pos<=len do
            skipWS();local ac=str:sub(pos,pos)
            if ac==']' then pos=pos+1;break end;if ac==',' then pos=pos+1;skipWS() end
            if str:sub(pos,pos)=='"' then local item=readString();if item then table.insert(arr,item) end else pos=pos+1 end
        end;return arr
    end
    skipWS();if str:sub(pos,pos)=='{' then pos=pos+1 end
    while pos<=len do
        skipWS();local c=str:sub(pos,pos)
        if c=='}' then break end;if c==',' then pos=pos+1;skipWS() end
        local key=readString();if not key then pos=pos+1;continue end
        skipWS();if str:sub(pos,pos)==':' then pos=pos+1 end;skipWS()
        if key=="keybind" then result.keybind=readString()
        elseif key=="speedValue" then result.speedValue=readNumber() or 16
        elseif key=="farm2PlantName" then result.farm2PlantName=readString() or "Durian"
        elseif key=="farmPlantName" then result.farmPlantName=readString() or "Durian"
        elseif key=="farm4PlantName" then result.farm4PlantName=readString() or "Durian"
        elseif key=="toggles" then
            if str:sub(pos,pos)=='{' then pos=pos+1 end
            while pos<=len do
                skipWS();local tc=str:sub(pos,pos)
                if tc=='}' then pos=pos+1;break end;if tc==',' then pos=pos+1;skipWS() end
                local tk=readString();if not tk then pos=pos+1;continue end
                skipWS();if str:sub(pos,pos)==':' then pos=pos+1 end
                local tv=readBool();if tk and tv~=nil then result.toggles[tk]=tv end
            end
        elseif str:sub(pos,pos)=='[' then result[key]=readArray()
        else while pos<=len and not str:sub(pos,pos):match('[,}%]]') do pos=pos+1 end end
    end;return result
end

