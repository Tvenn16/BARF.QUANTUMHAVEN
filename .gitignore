        local rStrip=Instance.new("Frame",rarityRow);rStrip.Size=UDim2.new(0,3,0.6,0);rStrip.Position=UDim2.new(0,0,0.2,0);rStrip.BackgroundColor3=rc;rStrip.BorderSizePixel=0;Instance.new("UICorner",rStrip).CornerRadius=UDim.new(1,0)
        local rLbl=Instance.new("TextLabel",rarityRow);rLbl.Size=UDim2.new(1,-54,1,0);rLbl.Position=UDim2.new(0,12,0,0);rLbl.BackgroundTransparency=1;rLbl.Text="✨  "..rarity;rLbl.TextColor3=rc;rLbl.TextSize=FS.normal;rLbl.Font=Enum.Font.GothamBold;rLbl.TextXAlignment=Enum.TextXAlignment.Left;rLbl.ZIndex=9
        local rBadge=Instance.new("TextLabel",rarityRow);rBadge.Size=UDim2.new(0,36,0,18);rBadge.Position=UDim2.new(1,-44,0.5,-9);rBadge.BackgroundColor3=C.toggleOff;rBadge.Text="OFF";rBadge.TextColor3=C.textDim;rBadge.TextSize=FS.small;rBadge.Font=Enum.Font.GothamBold;rBadge.BorderSizePixel=0;rBadge.ZIndex=9;Instance.new("UICorner",rBadge).CornerRadius=UDim.new(1,0)
        local rOn=false;local capRarity=rarity
        local function setRarityOn(s)
            rOn=s
            if s then selectedRarities[capRarity]=true;rBadge.Text="ON";TweenService:Create(rBadge,TweenInfo.new(0.15),{BackgroundColor3=C.toggleOn,TextColor3=Color3.fromRGB(0,0,0)}):Play();TweenService:Create(rarityRow,TweenInfo.new(0.1),{BackgroundColor3=C.rowHover}):Play()
            else selectedRarities[capRarity]=nil;rBadge.Text="OFF";TweenService:Create(rBadge,TweenInfo.new(0.15),{BackgroundColor3=C.toggleOff,TextColor3=C.textDim}):Play();TweenService:Create(rarityRow,TweenInfo.new(0.1),{BackgroundColor3=C.panel}):Play() end
        end
        rarityRow.MouseButton1Click:Connect(function() setRarityOn(not rOn) end)
        rarityRow.MouseEnter:Connect(function() if not rOn then TweenService:Create(rarityRow,TweenInfo.new(0.1),{BackgroundColor3=C.rowHover}):Play() end end)
        rarityRow.MouseLeave:Connect(function() if not rOn then TweenService:Create(rarityRow,TweenInfo.new(0.1),{BackgroundColor3=C.panel}):Play() end end)
        saveRegistry.toggles["rarityOn_"..rarity]={getState=function() return rOn end,setState=function(s) setRarityOn(s) end}
    end
end)

