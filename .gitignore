-- ══════════════════════════════════════════════
-- RESIZE HANDLE
-- ══════════════════════════════════════════════
local ResizeHandle=Instance.new("TextButton",Frame)
ResizeHandle.Size=UDim2.new(0,18,0,18);ResizeHandle.Position=UDim2.new(1,-18,1,-18)
ResizeHandle.BackgroundTransparency=1;ResizeHandle.Text=""
ResizeHandle.AutoButtonColor=false;ResizeHandle.ZIndex=100

local dragging,dragStart,dragFrameStart=false,Vector2.new(),UDim2.new()
TitleBar.InputBegan:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true;dragStart=Vector2.new(input.Position.X,input.Position.Y);local ap=Frame.AbsolutePosition;dragFrameStart=UDim2.new(0,ap.X,0,ap.Y) end end)
TitleBar.InputEnded:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
local resizing,resizeStart,resizeStartSz=false,Vector2.new(),Vector2.new()
ResizeHandle.InputBegan:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 then resizing=true;resizeStart=Vector2.new(input.Position.X,input.Position.Y);resizeStartSz=Vector2.new(Frame.AbsoluteSize.X,Frame.AbsoluteSize.Y) end end)
ResizeHandle.InputEnded:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 then resizing=false end end)
UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType~=Enum.UserInputType.MouseMovement then return end
    local p=Vector2.new(input.Position.X,input.Position.Y)
    if dragging then local d=p-dragStart;Frame.Position=UDim2.new(0,dragFrameStart.X.Offset+d.X,0,dragFrameStart.Y.Offset+d.Y) end
    if resizing then local d=p-resizeStart;Frame.Size=UDim2.new(0,math.max(MIN_W,resizeStartSz.X+d.X),0,math.max(MIN_H,resizeStartSz.Y+d.Y)) end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false;resizing=false end end)

-- ══════════════════════════════════════════════
-- SHOW / HIDE UI
-- ══════════════════════════════════════════════
local function showUI() Frame.Visible=true;FloatBtn.Visible=false end
local function hideUI()
    Frame.Visible=false;FloatBtn.Visible=true
    local char=player.Character;if char then local hum=char:FindFirstChildOfClass("Humanoid");if hum then hum.WalkSpeed=25 end end
end
MinBtn.MouseButton1Click:Connect(hideUI);FloatBtn.MouseButton1Click:Connect(showUI)
UserInputService.InputBegan:Connect(function(input,gpe)
    if gpe then return end
    if not listeningForKey and keybindEnabled and input.KeyCode==currentKeybind then
        if Frame.Visible then hideUI() else showUI() end
    end
end)

local function stopAll()
    active=false;rollEnabled=false;sellEnabled=false;buyEnabled=false;gearEnabled=false
    honeycombEnabled=false;ufoEnabled=false;discardEnabled=false;farmEnabled=false;farm2Enabled=false
    speedEnabled=false;infiniteJumpEnabled=false;flyEnabled=false;noclipEnabled=false
    autoShootEnabled=false;autoEquipTomato=false;rarityBuyAllEnabled=false
    setInfiniteJump(false);setFly(false);setNoclip(false)
    selectedSeeds={};selectedGear={};selectedDiscard={};selectedRarities={}
    for _,fn in ipairs(forceOffList) do fn() end
    local char=player.Character;if char then local hum=char:FindFirstChildOfClass("Humanoid");if hum then hum.WalkSpeed=25 end end
end
CloseBtn.MouseButton1Click:Connect(function() stopAll();Frame.Visible=false;FloatBtn.Visible=false end)

-- ══════════════════════════════════════════════
-- BACKGROUND LOOPS
-- ══════════════════════════════════════════════
task.spawn(function()
    while true do
        task.wait(0.2);if not active then continue end
        if buyEnabled then
            for _,seed in ipairs(Seeds) do
                if not selectedSeeds[seed.name] then continue end
                local obj=seed.find();if obj then local part=obj:FindFirstChild(seed.child);if part then local prompt=part:FindFirstChild(seed.prompt);if prompt then fireproximityprompt(prompt) end end end
            end
        end
        if rarityBuyAllEnabled then
            for _,seed in ipairs(Seeds) do
                if not selectedRarities[seed.rarity] then continue end
                local obj=seed.find();if obj then local part=obj:FindFirstChild(seed.child);if part then local prompt=part:FindFirstChild(seed.prompt);if prompt then fireproximityprompt(prompt) end end end
            end
        end
    end
end)
task.spawn(function()
    while true do
        task.wait(0.1);if not gearEnabled or not active then continue end
        for gearName in pairs(selectedGear) do
            if not gearEnabled or not active then break end
            pcall(function() GearEvent:InvokeServer(gearName) end);task.wait(3)
        end
    end
end)
task.spawn(function()
    local char=player.Character or player.CharacterAdded:Wait();local humanoid=char:WaitForChild("Humanoid")
    player.CharacterAdded:Connect(function(c) char=c;humanoid=c:WaitForChild("Humanoid") end)
    while true do
        task.wait(0.5);if not discardEnabled or not active then continue end
        local backpack=player:FindFirstChild("Backpack");if not backpack then continue end
        for seedEntryName in pairs(selectedDiscard) do
            if not discardEnabled or not active then break end
            local plainName=seedPlainNames[seedEntryName];if not plainName then continue end
            local toolName=plainName.." Seed"
            local tool=backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
            if not tool then continue end
            humanoid:EquipTool(tool);task.wait(0.35);DiscardEvent:FireServer();task.wait(0.35)
        end
    end
end)

doLoad()
setNavActive("Home")
